# Required — get free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Recommended — get free key at https://console.groq.com/keys
# Enables automatic fallback if Gemini's free tier rate-limits a request
GROQ_API_KEY=

# Optional — free tier at https://upstash.com (no card needed)
# Enables per-IP rate limiting (10 requests/minute)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
